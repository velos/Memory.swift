{
  "dataset": "academic_v2",
  "provenance": "merged_public_corpora",
  "synthetic_status": "mixed_external",
  "primary_use": "academic_research_retrieval",
  "license_scope": "commercial_safe",
  "source_datasets": [
    {
      "name": "allenai/qasper",
      "license": "CC-BY-4.0",
      "splits": [
        "train",
        "dev"
      ]
    }
  ],
  "known_limits": [
    "Queries are paper-level information-seeking questions from a scientific QA benchmark.",
    "Converted documents are entire papers, so retrieval difficulty is partly long-context driven.",
    "This corpus is better treated as an academic long-form retrieval benchmark than as software-engineering memory."
  ],
  "recommended_weight": "secondary",
  "promotion_status": "draft",
  "audit": {
    "sample_sizes": {
      "query_tags": 50,
      "document_tags": 25,
      "storage_cases": 50
    }
  },
  "tagging": {
    "backend": "minimax_anthropic_api",
    "model": "MiniMax-M2.5",
    "prompt_version": "2026-03-15-minimax-tagging-v1",
    "auto_accept_policy": "single_pass_document,single_pass_query_and_storage"
  }
}
